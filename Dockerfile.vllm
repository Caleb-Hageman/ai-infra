FROM vllm/vllm-openai:latest

ENV MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct

# OpenAI-compatible API (chat/completions). Cloud Run expects port 8080.
ENTRYPOINT ["/bin/sh", "-c", "exec python3 -m vllm.entrypoints.openai.api_server --model \"$MODEL_NAME\" --host 0.0.0.0 --port 8080 --gpu-memory-utilization 0.90"]
